{
  "permissions": {
    "allow": [
      "mcp__laravel-boost__application-info",
      "mcp__laravel-boost__database-schema",
      "Bash(php artisan:*)",
      "Bash(vendor/bin/pint --dirty --format agent)",
      "Bash(php -l app/Services/BkashService.php)",
      "Bash(php -l app/Services/SslcommerzeService.php)",
      "Bash(php -l app/Http/Controllers/PaymentController.php)",
      "Bash(php:*)",
      "Bash(for f:*)",
      "Bash(do php:*)",
      "Bash(done)",
      "mcp__laravel-boost__browser-logs",
      "mcp__laravel-boost__last-error",
      "Bash(npm list:*)",
      "mcp__laravel-boost__read-log-entries",
      "Bash(ls -t storage/logs/*.log)",
      "Bash(xargs tail:*)",
      "Bash(curl -s http://127.0.0.1:8000/admin/pos)",
      "Bash(curl -I http://127.0.0.1:8000/admin/pos)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "laravel-boost"
  ]
}
